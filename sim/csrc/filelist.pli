PLI_STUB_OBJS_OBJ1=_vcs_pli_stub_.o
PLI_STUB_OBJS_SRC1=_vcs_pli_stub_.c
PLI_STUB_OBJS += $(PLI_STUB_OBJS_OBJ1)
$(PLI_STUB_OBJS_OBJ1): $(PLI_STUB_OBJS_SRC1)
	@$(CC) -I/opt/synopsys/vcs/X-2025.06/include  -pipe -DVCS -DUVM_DPI_DO_TYPE_CHECK -fPIC -I/opt/synopsys/vcs/X-2025.06/include     -fno-strict-aliasing -fno-optimize-sibling-calls  -fPIC -c -o $(PLI_STUB_OBJS_OBJ1) $(PLI_STUB_OBJS_SRC1)
	@strip -g $(PLI_STUB_OBJS_OBJ1)
