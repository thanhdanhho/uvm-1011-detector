DPI_STUB_OBJS_OBJ0=./../simv.daidir/vc_hdrs.o
DPI_STUB_OBJS_SRC0=./../simv.daidir/vc_hdrs.c
DPI_STUB_OBJS += $(DPI_STUB_OBJS_OBJ0)
$(DPI_STUB_OBJS_OBJ0): $(DPI_STUB_OBJS_SRC0)
	@$(CC) -I/opt/synopsys/vcs/X-2025.06/include  -pipe -DVCS -DUVM_DPI_DO_TYPE_CHECK -fPIC -I/opt/synopsys/vcs/X-2025.06/include     -fno-strict-aliasing -fno-optimize-sibling-calls  -fPIC -c -o $(DPI_STUB_OBJS_OBJ0) $(DPI_STUB_OBJS_SRC0)
	@strip -g $(DPI_STUB_OBJS_OBJ0)
